 ],
 "fields": [
  {
   "fieldname": "naming_series",
   "fieldtype": "Select",
   "label": "Series",
   "options": "SAC-.YYYY.-.####",
   "default": "SAC-.YYYY.-.####",
   "reqd": 1,
   "print_hide": 1
  },
  {
   "fieldname": "employee",
   "fieldtype": "Link",
   "label": "Employee",
   "options": "Employee",
   "reqd": 1,
   "in_list_view": 1,
   "in_standard_filter": 1
  },
  {
   "fieldname": "employee_name",
   "fieldtype": "Data",
   "label": "Employee Name",
   "fetch_from": "employee.employee_name",
   "read_only": 1,
   "in_list_view": 1
  },
  {
   "fieldname": "department",
   "fieldtype": "Link",
   "label": "Department",
   "options": "Department",
   "fetch_from": "employee.department",
   "read_only": 1,
   "in_standard_filter": 1
  },
  {
   "fieldname": "column_break_top",
   "fieldtype": "Column Break"
  },
  {
   "fieldname": "saas_application",
   "fieldtype": "Link",
   "label": "SaaS Application",
   "options": "SaaS Application",
   "reqd": 1,
   "in_list_view": 1,
   "in_standard_filter": 1
  },
  {
   "fieldname": "app_name",
   "fieldtype": "Data",
   "label": "Application Name",
   "fetch_from": "saas_application.app_name",
   "read_only": 1
  },
  {
   "fieldname": "subscription_model",
   "fieldtype": "Data",
   "label": "Subscription Model",
   "fetch_from": "saas_application.subscription_model",
   "read_only": 1,
   "in_list_view": 1,
   "description": "Inherited from the SaaS Application. Drives form visibility on this record."
  },
  {
   "fieldname": "tier_or_plan",
   "fieldtype": "Link",
   "label": "Tier / Plan",
   "options": "SaaS Tier",
   "in_list_view": 1,
   "in_standard_filter": 1,
   "description": "Tier this seat sits on. Filtered by the parent SaaS Application. Required when the parent app has any active tier rows."
  },
  {
   "fieldname": "role_on_app",
   "fieldtype": "Data",
   "label": "Role on App",
   "default": "Member",
   "description": "Admin / Member / Owner. Informational."
  },
  {
   "fieldname": "revoke_on_offboarding",
   "fieldtype": "Check",
   "label": "Revoke on Offboarding",
   "default": 1,
   "description": "When this employee leaves, should we revoke this account? Uncheck for shared service accounts (marketing@, bot users, break-glass admins) where the seat should be transferred rather than revoked. Set once at access-creation time."
  },
  {
   "fieldname": "access_section",
   "fieldtype": "Section Break",
   "label": "Access"
  },
  {
   "fieldname": "granted_date",
   "fieldtype": "Date",
   "label": "Granted Date",
   "default": "Today"
  },
  {
   "fieldname": "last_login",
   "fieldtype": "Date",
   "label": "Last Login"
  },
  {
   "fieldname": "monthly_cost_share",
   "fieldtype": "Currency",
   "label": "Monthly Cost Share",
   "options": "currency",
   "description": "Optional for Shared; required for Per-User."
  },
  {
   "fieldname": "column_break_access",
   "fieldtype": "Column Break"
  },
  {
   "fieldname": "currency",
   "fieldtype": "Link",
   "label": "Currency",
   "options": "Currency",
   "default": "AED",
   "fetch_from": "saas_application.currency"
  },
  {
   "fieldname": "subscription_status",
   "fieldtype": "Select",
   "label": "Subscription Status",
   "options": "Active\nPaused\nCancelled",
   "default": "Active",
   "reqd": 1,
   "in_standard_filter": 1,
   "description": "Orthogonal to revoke_status. Paused = user kept the seat but isn't billing this month (e.g. parental leave); Cancelled = seat ended but credential cleanup may still be pending."
  },
  {
   "fieldname": "per_user_section",
   "fieldtype": "Section Break",
   "label": "Per-User Contract",
   "description": "Used only when the parent application's subscription_model = Per-User. Hidden via Client Script otherwise.",
   "depends_on": "eval:doc.subscription_model == 'Per-User'"
  },
  {
   "fieldname": "per_user_renewal_date",
   "fieldtype": "Date",
   "label": "Renewal Date",
   "mandatory_depends_on": "eval:doc.subscription_model == 'Per-User'"
  },
  {
   "fieldname": "column_break_per_user",
   "fieldtype": "Column Break"
  },
  {
   "fieldname": "per_user_billing_cycle",
   "fieldtype": "Select",
   "label": "Billing Cycle",
   "options": "Monthly\nQuarterly\nAnnual\nMulti-year",
   "default": "Monthly"
  },
  {
   "fieldname": "revoke_section",
   "fieldtype": "Section Break",
   "label": "Revocation"
  },
  {
   "fieldname": "revoke_status",
   "fieldtype": "Select",
   "label": "Revoke Status",
   "options": "Active\nPending Revoke\nIn Progress\nRevoked",
   "default": "Active",
   "reqd": 1,
   "in_list_view": 1,
   "in_standard_filter": 1
  },
  {
   "fieldname": "revoked_date",
   "fieldtype": "Date",
   "label": "Revoked Date"
  },
  {
   "fieldname": "column_break_revoke",
   "fieldtype": "Column Break"
  },
  {
   "fieldname": "revoked_by",
   "fieldtype": "Link",
   "label": "Revoked By",
   "options": "User"
  },
  {
   "fieldname": "revoke_reason",
   "fieldtype": "Small Text",
   "label": "Revoke Reason"
  }
 ],
